<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:PakTool" x:Class="PakTool.MainWindow" Title="SpellForce Pak Tool" Width="800" Height="600" WindowStartupLocation="CenterScreen">
	<Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="320,*">
		<TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="SpellForce Pak Tool" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,20"/>
		<ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
			<StackPanel Spacing="10" Margin="20,0,10,0">
				<TextBlock Text="Unpack Archive" FontWeight="Bold"/>
				<Button Name="BtnOpenPak" Content="Open .PAK Archive" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
				<Button Name="BtnUnpack" Content="Extract All" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsEnabled="False"/>
				<Button Name="BtnBatchUnpack" Content="Batch Unpack All .PAK" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
				<Separator Margin="0,5"/>
				<TextBlock Text="Pack Archive" FontWeight="Bold"/>
				<Button Name="BtnOpenFolder" Content="Select Folder" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
				<Button Name="BtnPack" Content="Pack to .PAK" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" IsEnabled="False"/>
			</StackPanel>
		</ScrollViewer>
		<Border Grid.Row="1" Grid.Column="1" Background="#1E1E1E" CornerRadius="5" Margin="10,0,20,0" BorderBrush="#333333" BorderThickness="1">
			<TreeView Name="FileTree">
				<TreeView.ItemTemplate>
					<TreeDataTemplate DataType="local:FileTreeNode" ItemsSource="{Binding Children}">
						<StackPanel Orientation="Horizontal" Spacing="5">
							<TextBlock Text="{Binding Name}"/>
						</StackPanel>
					</TreeDataTemplate>
				</TreeView.ItemTemplate>
			</TreeView>
		</Border>
		<Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2D2D30" CornerRadius="5" Padding="10" Margin="20,20,20,20">
			<TextBlock Name="TxtLog" Text="Ready." Foreground="#4CAF50" TextWrapping="Wrap"/>
		</Border>
	</Grid>
</Window>
